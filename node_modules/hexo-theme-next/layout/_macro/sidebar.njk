{% macro render(display_toc) %}
  <aside class="sidebar">
    {%- if display_toc %}
      {%- set toc = toc(page.content, {class: 'nav', list_number: page.toc.number, max_depth: page.toc.max_depth}) %}
      {%- set display_toc = toc.length > 1 and display_toc %}
    {%- endif %}

    {%- if display_toc %}
    <div class="sidebar-inner sidebar-toc-active">
      {%- if theme.back2top.enable and theme.back2top.sidebar %}
        <div class="back-to-top" role="button" aria-label="{{ __('accessibility.back_to_top') }}" style="margin-top: 0px">
          <i class="fa fa-book"></i>
          <span>Table of Contents</span>
        </div>
      {%- endif %}

      <div class="sidebar-panel-container">
        <div class="post-toc-wrap sidebar-panel">
          <div class="post-toc animated">{{ toc }}</div>
        </div>
      </div>
    </div>
    {% else %}
    <div class="sidebar-inner sidebar-blogroll">
      <div>
        {%- if theme.links_settings.icon %}<i class="{{ theme.links_settings.icon }} fa-fw"></i>{% endif %}
        {{ theme.links_settings.name }}
      </div>
      <div class="sidebar-panel-container">
        <div class="links-of-blogroll animated">
          <ul class="links-of-blogroll-list">
            {%- for blogrollText, blogrollURL in theme.links %}
              <li class="links-of-blogroll-item">
                {{ next_url(blogrollURL, blogrollText, {title: blogrollURL}) }}
              </li>
            {%- endfor %}
          </ul>
        </div>
      </div>
    </div>
    {%- endif %}

    {# Blogroll #}
    {%- if theme.related_posts.enable %}
      {%- if theme.pjax %}
        <div class="pjax">
      {%- endif %}
      {%- if page.embedding_vector %}
        {% set _ = related_posts(page) %}
      {%- endif %}
      {%- if page.related_posts and page.related_posts.length > 0 %}
        <div class="sidebar-inner sidebar-post-related">
          <div class="animated">
            {{ partial('_partials/post/post-related.njk') }}
          </div>
        </div>
      {%- endif %}
      {%- if theme.pjax %}
        </div>
      {%- endif %}
    {%- endif %}
  </aside>
{% endmacro %}
